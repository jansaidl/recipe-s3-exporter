# Copy to .env and adjust for local development.

# PostgreSQL connection string (required).
DATABASE_URL=postgres://postgres:secret@127.0.0.1:5432/exporter?sslmode=disable

# Secret-encryption master key (required). Either base64 of 32 random bytes
# (openssl rand -base64 32) or a literal 32-character string.
MASTER_KEY=

# First admin account, created automatically on first boot if no users exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Optional.
PORT=8080
EXPORT_WORKERS=2
SECURE_COOKIES=false
ZEROPS_API=https://api.app-prg1.zerops.io/api/rest/public
# Authorization scheme for Zerops API calls. Default "Bearer" (per the spec).
# Set to "none" (or "raw") to send the raw token with no scheme prefix.
ZEROPS_AUTH_SCHEME=Bearer
